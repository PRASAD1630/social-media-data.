import streamlit as st
import pandas as pd
import plotly.express as px
import numpy as np

# ---------------- PAGE CONFIG ----------------
st.set_page_config(page_title="Instagram AI Dashboard", layout="wide")

# ---------------- LOAD DATA ----------------
@st.cache_data
def load_data():
    return pd.read_csv("instagram_preprocessed.csv")

df = load_data()

# Add engagement rate if not present
if 'engagement_rate' not in df.columns:
    df['engagement_rate'] = (df['engagement'] / (df['likes_count'] + 1)) * 100

# ---------------- SIDEBAR ----------------
st.sidebar.title("📊 Controls")

language = st.sidebar.selectbox("Language", df['language'].unique())

# Handle missing media_type safely
if 'media_type' in df.columns:
    media = st.sidebar.selectbox("Media Type", df['media_type'].unique())
    df_filtered = df[(df['language'] == language) & (df['media_type'] == media)]
else:
    df_filtered = df[df['language'] == language]

page = st.sidebar.radio("Navigate", [
    "Overview",
    "Engagement",
    "Advanced",
    "Performance Metrics",
    "Data"
])

# ---------------- HEADER ----------------
st.title("🚀 Instagram AI Analytics Dashboard")

c1, c2, c3, c4, c5 = st.columns(5)

c1.metric("Total Posts", len(df_filtered))
c2.metric("Avg Likes", f"{int(df_filtered['likes_count'].mean()):,}")
c3.metric("Avg Comments", f"{int(df_filtered['comments_count'].mean())}")
c4.metric("Avg Engagement", f"{int(df_filtered['engagement'].mean()):,}")
c5.metric("Avg Engagement Rate", f"{df_filtered['engagement_rate'].mean():.2f}%")

st.markdown("---")

# ===================== OVERVIEW =====================
if page == "Overview":

    col1, col2 = st.columns(2)

    # FIXED LANGUAGE DISTRIBUTION
    lang_counts = df['language'].value_counts().reset_index()
    lang_counts.columns = ['language', 'count']

    fig1 = px.bar(
        lang_counts,
        x='language',
        y='count',
        color='count',
        title="🌍 Language Distribution",
        color_continuous_scale='Viridis'
    )
    col1.plotly_chart(fig1, use_container_width=True)

    # SENTIMENT (SAFE)
    if 'sentiment' in df.columns:
        fig2 = px.pie(
            df_filtered,
            names='sentiment',
            title="😊 Sentiment Distribution"
        )
        col2.plotly_chart(fig2, use_container_width=True)
    else:
        col2.warning("Sentiment column not available")

    # Additional overview metrics
    st.subheader("📈 Key Insights")
    
    col1, col2, col3 = st.columns(3)
    
    best_performing_location = df_filtered.groupby('location')['engagement'].mean().idxmax()
    col1.write(f"**Top Location:** {best_performing_location}")
    
    best_media_type = df_filtered.groupby('media_type')['engagement'].mean().idxmax()
    col2.write(f"**Best Media Type:** {best_media_type}")
    
    sentiment_count = df_filtered['sentiment'].value_counts().idxmax()
    col3.write(f"**Dominant Sentiment:** {sentiment_count}")

# ===================== ENGAGEMENT =====================
elif page == "Engagement":

    col1, col2 = st.columns(2)

    # Scatter
    fig1 = px.scatter(
        df_filtered.sample(min(3000, len(df_filtered))),
        x='hashtag_count',
        y='engagement',
        color='language',
        size='likes_count',
        title="📊 Hashtags vs Engagement"
    )
    col1.plotly_chart(fig1, use_container_width=True)

    # Histogram
    fig2 = px.histogram(
        df_filtered,
        x='likes_count',
        nbins=50,
        title="📉 Likes Distribution",
        color_discrete_sequence=['#636EFA']
    )
    col2.plotly_chart(fig2, use_container_width=True)

    # Time-based analysis
    st.subheader("⏰ Hourly Engagement Pattern")
    hourly_data = df_filtered.groupby('hour')[['likes_count', 'comments_count', 'engagement']].mean().reset_index()
    
    fig3 = px.line(
        hourly_data,
        x='hour',
        y='engagement',
        markers=True,
        title="Engagement by Hour of Day"
    )
    st.plotly_chart(fig3, use_container_width=True)

# ===================== ADVANCED =====================
elif page == "Advanced":

    col1, col2 = st.columns(2)

    # CORRELATION MATRIX
    num_cols = [
        'likes_count','comments_count','shares_count',
        'engagement','caption_length','word_count','hashtag_count'
    ]

    existing_cols = [c for c in num_cols if c in df_filtered.columns]

    if len(existing_cols) > 0:
        corr = df_filtered[existing_cols].corr()

        fig1 = px.imshow(
            corr,
            text_auto=True,
            title="📊 Correlation Matrix",
            color_continuous_scale='RdBu'
        )
        col1.plotly_chart(fig1, use_container_width=True)
    else:
        col1.warning("No numeric columns available")

    # FIXED TOP HASHTAGS
    if 'hashtags' in df_filtered.columns:
        tags = df_filtered['hashtags'].astype(str).str.split().explode()
        top_tags = tags.value_counts().head(10).reset_index()
        top_tags.columns = ['tag', 'count']

        fig2 = px.bar(
            top_tags,
            x='count',
            y='tag',
            orientation='h',
            title="🔥 Top Hashtags",
            color='count',
            color_continuous_scale='Sunset'
        )
        col2.plotly_chart(fig2, use_container_width=True)
    else:
        col2.warning("Hashtags column missing")

# ===================== PERFORMANCE METRICS =====================
elif page == "Performance Metrics":

    st.subheader("📊 Performance Analysis")

    col1, col2 = st.columns(2)

    # Media Type Performance
    media_perf = df_filtered.groupby('media_type').agg({
        'likes_count': 'mean',
        'engagement': 'mean',
        'post_id': 'count'
    }).reset_index()
    media_perf.columns = ['media_type', 'avg_likes', 'avg_engagement', 'total_posts']

    fig1 = px.bar(
        media_perf,
        x='media_type',
        y=['avg_likes', 'avg_engagement'],
        title="Performance by Media Type",
        barmode='group'
    )
    col1.plotly_chart(fig1, use_container_width=True)

    # Location Performance
    location_perf = df_filtered.groupby('location')['engagement'].mean().reset_index()
    location_perf = location_perf.sort_values('engagement', ascending=True)

    fig2 = px.bar(
        location_perf,
        y='location',
        x='engagement',
        orientation='h',
        title="Avg Engagement by Location",
        color='engagement',
        color_continuous_scale='Greens'
    )
    col2.plotly_chart(fig2, use_container_width=True)

    # Language Performance
    st.subheader("Language Performance")
    lang_perf = df_filtered.groupby('language').agg({
        'likes_count': 'mean',
        'engagement': 'mean',
        'engagement_rate': 'mean'
    }).reset_index().sort_values('engagement', ascending=False)

    fig3 = px.bar(
        lang_perf,
        x='language',
        y='engagement',
        color='engagement_rate',
        title="Engagement by Language (colored by rate)",
        color_continuous_scale='Viridis'
    )
    st.plotly_chart(fig3, use_container_width=True)

