    "plt.colorbar(scatter, label='Likes Count')\n",
    "plt.title(\"t-SNE Visualization of Text Embeddings\")\n",
    "plt.xlabel(\"t-SNE Dimension 1\")\n",
    "plt.ylabel(\"t-SNE Dimension 2\")\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
